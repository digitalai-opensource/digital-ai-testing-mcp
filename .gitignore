# Environment — NEVER commit
.env
.env.local
.env.*.local

# Build output
node_modules/
dist/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Credentials — NEVER commit
*.p12
*.mobileprovision
*.pem
*.key
*.cer
*.crt
.npmrc

# Test artifacts
tests/fixtures/
coverage/

# Claude Code local state
.claude/

# MCP Config local state
.mcp.json

# Developer guide — contains internal implementation notes not intended for public distribution.
# Share manually with developer workstations; not needed by the MCP runtime.
CLAUDE.md

# Docs — only the customer-facing docs ship with the product (the README links
# into each); everything else (gap analyses, UAT suite, API mapping, publishing
# guide) is internal tooling kept locally.
docs/*.md
!docs/tools.md
!docs/examples.md
!docs/limitations.md
!docs/recommended-agent-guardrails.md
