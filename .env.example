# ============================================================
# Digital.ai Continuous Testing — MCP Server Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# Required: Default connection (active on startup)
DIGITAL_AI_BASE_URL=https://your-tenant.experitest.com
DIGITAL_AI_ACCESS_KEY=your_access_key_here

# MCP Server identity (shown in Claude tool picker)
MCP_SERVER_NAME=digital-ai-testing-mcp
MCP_SERVER_VERSION=1.0.0

# Timeouts in milliseconds
REQUEST_TIMEOUT_MS=30000
UPLOAD_TIMEOUT_MS=120000

# ============================================================
# Named environments (optional)
#
# The most common use case is switching between projects on
# the same instance — for example, a Cloud Admin key for
# administration and one or more project-scoped API keys for
# day-to-day test work:
#
#   DAI_PROFILE_{NAME}_URL=https://...      (same URL as above is fine)
#   DAI_PROFILE_{NAME}_KEY=your_key_here
#
# Use list_environments to see all configured profiles and
# switch_environment("<name>") to switch between them without
# restarting. All subsequent tool calls use the new credentials
# immediately.
# ============================================================

# Example — switching between a Cloud Admin key and two project keys
# on the same instance (the most common setup):
#
# DAI_PROFILE_ADMIN_URL=https://your-tenant.experitest.com
# DAI_PROFILE_ADMIN_KEY=eyJ...your_cloud_admin_jwt...
#
# DAI_PROFILE_QA_URL=https://your-tenant.experitest.com
# DAI_PROFILE_QA_KEY=aut_1_...your_qa_project_key...
#
# DAI_PROFILE_POC_URL=https://your-tenant.experitest.com
# DAI_PROFILE_POC_KEY=aut_1_...your_poc_project_key...

# Example — switching between instances (less common):
#
# DAI_PROFILE_STAGING_URL=https://staging.experitest.com
# DAI_PROFILE_STAGING_KEY=your_staging_key_here
#
# DAI_PROFILE_EU_URL=https://eu.experitest.com
# DAI_PROFILE_EU_KEY=your_eu_key_here
